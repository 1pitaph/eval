{
  "name": "@eval/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts",
    "./app": "./src/app.ts",
    "./artifact-store": "./src/services/artifactStore.ts",
    "./sqlite-store": "./src/lib/sqliteStore.ts",
    "./store": "./src/lib/store.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "eval:run": "tsx src/cli/runEval.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@eval/workflow-schema": "workspace:*",
    "@fastify/cors": "11.2.0",
    "fastify": "5.8.5",
    "nanoid": "5.1.11",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "tsx": "4.22.4"
  }
}
