{
  "name": "eval-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --no-bail --filter @eval/web --filter @eval/api dev",
    "dev:api": "pnpm --filter @eval/api dev",
    "dev:desktop": "pnpm --filter @eval/web build && pnpm --filter @eval/desktop dev",
    "dev:web": "pnpm --filter @eval/web dev",
    "build:desktop": "pnpm --filter @eval/web build && pnpm --filter @eval/desktop build",
    "dist:desktop": "pnpm --filter @eval/web build && pnpm --filter @eval/desktop dist",
    "dist:desktop:release": "pnpm --filter @eval/web build && pnpm --filter @eval/desktop dist:signed",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  }
}
